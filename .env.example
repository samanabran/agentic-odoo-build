# ── Odoo ──────────────────────────────────────────────────────────────────────
ODOO_VERSION=18.0
ODOO_DB_NAME=ai_brain_dev
ODOO_ADMIN_PASSWORD=change_me

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo
POSTGRES_DB=postgres

# ── Orchestrator ──────────────────────────────────────────────────────────────
ORCH_PORT=8088
# Generate with: openssl rand -hex 32
ORCH_JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
ORCH_REDIS_URL=redis://redis:6379/0

# ── Environment and routing (D3) ──────────────────────────────────────────────
# Valid values: "development" | "production"
# "development" -> LiteLLM github-dev model (requires GITHUB_TOKEN)
# "production"  -> LiteLLM prod-default model (Anthropic claude-haiku)
# PRIVATE_MODE=true overrides ENVIRONMENT and routes to prod-local (Ollama)
ENVIRONMENT=development
PRIVATE_MODE=false

# ── LLM provider keys ────────────────────────────────────────────────────────
# At least one of ANTHROPIC_API_KEY or OPENAI_API_KEY is required in production.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── GitHub Models — development and eval harness only (D1, ADR 0003) ─────────
# Required when ENVIRONMENT=development. NEVER set in production.
# https://github.com/settings/tokens (no special scopes required)
GITHUB_TOKEN=

# ── Private mode — Ollama local LLM ──────────────────────────────────────────
# Only used when PRIVATE_MODE=true. Requires `make up-private`.
OLLAMA_BASE_URL=http://ollama:11434
LOCAL_MODEL=qwen2.5:7b
# Set to true to skip the ~4 GB model download on first boot
OLLAMA_SKIP_PULL=false

# ── Cost controls (D6) ───────────────────────────────────────────────────────
USER_DAILY_BUDGET_TOKENS=50000
TENANT_MONTHLY_BUDGET_USD=200

# ── LiteLLM virtual key provisioning (M2) ───────────────────────────────────
# Generate the master key with: openssl rand -hex 32
# Virtual keys (VKEY_*) are populated automatically by:
#   bash scripts/provision_litellm_keys.sh
# Do NOT manually set VKEY_* — they are scoped per model by LiteLLM.
LITELLM_MASTER_KEY=
# Generate with: openssl rand -hex 32 -- required for encrypting stored virtual keys at rest
LITELLM_SALT_KEY=
LITELLM_VKEY_CLOUD_DEV=
LITELLM_VKEY_LOCAL=

# ── Observability (G2) ───────────────────────────────────────────────────────
# OTLP HTTP endpoint for OpenTelemetry traces. Jaeger UI at http://localhost:16686
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
