<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="dashboard" name="AI Brain Financial Dashboard">
        <html>
            <head>
                <meta http-equiv="refresh" content="60"/>
                <title>AI Brain - Financial Intelligence</title>
                <style>
                    body { font-family: Arial, sans-serif; margin: 20px; background: #f7f9fc; color: #1f2937; }
                    h1, h2, h3 { margin-bottom: 0.5rem; }
                    .meta { color: #6b7280; margin-bottom: 20px; }
                    .flash { padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; }
                    .flash-success { background: #e8f7ee; color: #166534; border: 1px solid #86efac; }
                    .flash-error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
                    .card { border: 1px solid #dbe3ef; background: #fff; border-radius: 12px; padding: 18px; margin: 12px 0; box-shadow: 0 2px 6px rgba(15, 23, 42, 0.05); }
                    .stats { display: flex; gap: 12px; flex-wrap: wrap; margin: 10px 0 18px; }
                    .stat { min-width: 120px; padding: 12px; border-radius: 10px; background: #f8fafc; border: 1px solid #e2e8f0; }
                    .stat strong { display: block; font-size: 1.4rem; }
                    .confidence-grid { display: grid; gap: 10px; }
                    .confidence-row { display: grid; grid-template-columns: 110px 1fr 50px; gap: 12px; align-items: center; }
                    .confidence-bar { background: #e5e7eb; border-radius: 999px; overflow: hidden; height: 14px; }
                    .confidence-fill { height: 100%; background: linear-gradient(90deg, #2563eb, #0ea5e9); }
                    table { width: 100%; border-collapse: collapse; margin-top: 10px; }
                    th, td { padding: 10px; border-bottom: 1px solid #e5e7eb; text-align: left; vertical-align: top; }
                    th { background: #f8fafc; }
                    .badge { display: inline-block; border-radius: 999px; padding: 2px 8px; font-size: 0.85rem; font-weight: bold; text-transform: capitalize; }
                    .badge-high { background: #dc3545; color: white; }
                    .badge-medium { background: #ffc107; color: black; }
                    .badge-low { background: #28a745; color: white; }
                    .session-list { margin: 0; padding-left: 18px; }
                    .session-list li { margin: 8px 0; }
                    .muted { color: #6b7280; }
                    .actions { margin-top: 16px; display: flex; gap: 10px; align-items: end; flex-wrap: wrap; }
                    .actions label { display: grid; gap: 6px; font-weight: bold; }
                    input[type="number"] { padding: 8px 10px; border: 1px solid #cbd5e1; border-radius: 8px; min-width: 160px; }
                    button { background: #111827; color: #fff; border: 0; border-radius: 8px; padding: 10px 14px; cursor: pointer; }
                    button:hover { background: #1f2937; }
                    .narrative { max-width: 480px; }
                </style>
            </head>
            <body>
                <h1>AI Brain — Financial Intelligence</h1>
                <p class="meta">Last refresh: <t t-esc="datetime.datetime.now()"/></p>

                <t t-if="flash_message">
                    <div t-att-class="'flash flash-' + flash_message.get('level', 'success')">
                        <t t-esc="flash_message.get('message')"/>
                    </div>
                </t>

                <div class="card">
                    <h2>Reconciliation Sessions</h2>
                    <div class="stats">
                        <div class="stat">
                            <span class="muted">Completed Sessions</span>
                            <strong><t t-esc="len(sessions)"/></strong>
                        </div>
                        <div class="stat">
                            <span class="muted">High Confidence</span>
                            <strong><t t-esc="confidence_dist['95_plus']"/></strong>
                        </div>
                        <div class="stat">
                            <span class="muted">Manual Review</span>
                            <strong><t t-esc="confidence_dist['under_65']"/></strong>
                        </div>
                    </div>

                    <h3>Confidence Distribution</h3>
                    <div class="confidence-grid">
                        <t t-foreach="confidence_bars" t-as="bar">
                            <div class="confidence-row">
                                <span><t t-esc="bar['label']"/></span>
                                <div class="confidence-bar"><div class="confidence-fill" t-att-style="'width: ' + str(bar['width']) + '%'"/></div>
                                <span><t t-esc="bar['count']"/></span>
                            </div>
                        </t>
                    </div>

                    <t t-if="sessions">
                        <ul class="session-list">
                            <t t-foreach="sessions" t-as="session">
                                <li>
                                    Session #<t t-esc="session.id"/> — Statement
                                    <t t-esc="session.statement_id.display_name or session.statement_id.id or 'N/A'"/>
                                    — <strong><t t-esc="len(session.suggestion_ids)"/></strong> suggestions
                                </li>
                            </t>
                        </ul>
                    </t>
                    <t t-else="">
                        <p class="muted">No completed reconciliation sessions yet.</p>
                    </t>

                    <form class="actions" action="/ai_brain/reconcile" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <label>
                            Statement ID
                            <input type="number" name="statement_id" min="1" required="required"/>
                        </label>
                        <button type="submit">Run Reconciliation</button>
                    </form>
                </div>

                <div class="card">
                    <h2>AML Alerts</h2>
                    <t t-if="alerts">
                        <table>
                            <tr>
                                <th>Partner</th>
                                <th>Type</th>
                                <th>Severity</th>
                                <th>Date</th>
                                <th>Narrative</th>
                            </tr>
                            <t t-foreach="alerts" t-as="alert">
                                <tr>
                                    <td><t t-esc="alert.partner_id.name or '—'"/></td>
                                    <td><t t-esc="alert.alert_type"/></td>
                                    <td>
                                        <span t-att-class="'badge badge-' + (alert.severity or 'low')">
                                            <t t-esc="alert.severity"/>
                                        </span>
                                    </td>
                                    <td><t t-esc="alert.create_date"/></td>
                                    <td class="narrative"><t t-esc="(alert.narrative or '')[:160] or '—'"/></td>
                                </tr>
                            </t>
                        </table>
                    </t>
                    <t t-else="">
                        <p>No active alerts</p>
                    </t>
                </div>
            </body>
        </html>
    </template>
</odoo>
