<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ai_brain.AiBrainPanel" owl="1">
        <div class="o_action o_ai_brain_panel">

            <!-- LEFT: Quick Commands sidebar -->
            <div class="o_ai_brain_sidebar">
                <p class="o_ai_sidebar_title">Quick Commands</p>
                <div class="o_ai_brain_btn_list">
                    <t t-foreach="actions" t-as="action" t-key="action.id">
                        <button
                            t-attf-class="o_ai_brain_btn o_ai_btn_{{ action.color }}{{ state.activeId === action.id ? ' o_ai_active' : '' }}"
                            t-on-click="() => this.onActionClick(action)"
                            t-att-disabled="state.loading">
                            <i t-attf-class="fa {{ action.icon }} o_ai_btn_icon"/>
                            <span t-esc="action.label"/>
                        </button>
                    </t>
                </div>
            </div>

            <!-- RIGHT: Report area + Chat input -->
            <div class="o_ai_brain_main">

                <!-- TOP: large report / dashboard output area -->
                <div class="o_ai_brain_output">

                    <!-- Report header bar (only when report is loaded or error) -->
                    <t t-if="state.replyHtml or state.error">
                        <div class="o_ai_brain_report_bar">
                            <span class="o_ai_report_title">
                                <i class="fa fa-bar-chart"/> <strong t-esc="this.getActiveLabel()"/>
                            </span>
                            <div class="o_ai_report_actions">
                                <button t-if="state.replyHtml"
                                        class="btn btn-sm btn-outline-primary"
                                        t-on-click="onDownloadReport"
                                        title="Download report as PDF">
                                    <i class="fa fa-file-pdf-o"/> PDF
                                </button>
                                <button class="btn btn-sm btn-outline-secondary"
                                        t-on-click="onClear">
                                    <i class="fa fa-times"/> Clear
                                </button>
                            </div>
                        </div>
                    </t>

                    <!-- Loading state (all commands, including custom chat) -->
                    <t t-if="state.loading">
                        <div class="o_ai_brain_loading">
                            <i class="fa fa-spinner fa-spin fa-2x"/>
                            <p>Analysing your data…</p>
                        </div>
                    </t>

                    <!-- Error state -->
                    <t t-elif="state.error">
                        <div class="o_ai_brain_result_body">
                            <div class="alert alert-danger mt-2">
                                <i class="fa fa-exclamation-triangle"/>
                                <strong> Error: </strong>
                                <t t-esc="state.error"/>
                            </div>
                        </div>
                    </t>

                    <!-- Report HTML -->
                    <t t-elif="state.replyHtml">
                        <div class="o_ai_brain_result_body" t-out="state.replyHtml"/>
                    </t>

                    <!-- Empty placeholder -->
                    <t t-else="">
                        <div class="o_ai_brain_empty">
                            <i class="fa fa-bar-chart fa-3x"/>
                            <p>Select a Quick Command or ask a question below</p>
                            <p class="o_ai_empty_sub">Reports and answers appear here</p>
                        </div>
                    </t>
                </div>

                <!-- BOTTOM: Chat input bar -->
                <div class="o_ai_brain_chat">

                    <div class="o_ai_chat_header">
                        <span><i class="fa fa-comments-o"/> AI Assistant</span>
                    </div>

                    <div class="o_ai_brain_input_bar">
                        <input
                            type="text"
                            id="ai_brain_message"
                            name="ai_brain_message"
                            autocomplete="off"
                            class="o_ai_message_input"
                            placeholder="Ask a question…"
                            t-model="state.customPrompt"
                            t-on-keydown="onKeydown"
                            t-att-disabled="state.loading"
                        />
                        <button class="o_ai_send_btn"
                                aria-label="Send message"
                                t-on-click="onAsk"
                                t-att-disabled="state.loading or !state.customPrompt">
                            <i t-attf-class="fa {{ state.loading and state.activeId === 'custom' ? 'fa-spinner fa-spin' : 'fa-arrow-right' }}"/>
                        </button>
                    </div>

                </div>
            </div>

        </div>
    </t>
</templates>
