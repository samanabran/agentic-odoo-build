<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="ai_brain.AiBrainPanel" owl="1">
        <div class="o_action o_ai_brain_panel">

            <!-- LEFT: Quick Commands sidebar -->
            <div class="o_ai_brain_sidebar">
                <p class="o_ai_sidebar_title">Quick Commands</p>
                <div class="o_ai_brain_btn_list">
                    <t t-foreach="actions" t-as="action" t-key="action.id">
                        <button
                            t-attf-class="o_ai_brain_btn o_ai_btn_{{ action.color }}{{ state.activeId === action.id ? ' o_ai_active' : '' }}"
                            t-on-click="() => this.onActionClick(action)"
                            t-att-disabled="state.loading">
                            <i t-attf-class="fa {{ action.icon }} o_ai_btn_icon"/>
                            <span t-esc="action.label"/>
                        </button>
                    </t>
                </div>
            </div>

            <!-- RIGHT: Output + status bar + message input -->
            <div class="o_ai_brain_main">

                <!-- Top: large output / dashboard area -->
                <div class="o_ai_brain_output">
                    <t t-if="state.loading">
                        <div class="o_ai_brain_loading">
                            <i class="fa fa-spinner fa-spin fa-2x"/>
                            <p>Analysing your data…</p>
                        </div>
                    </t>

                    <t t-elif="state.error">
                        <div class="o_ai_brain_result_body">
                            <div class="alert alert-danger mt-2">
                                <i class="fa fa-exclamation-triangle"/>
                                <strong> Error: </strong>
                                <t t-esc="state.error"/>
                            </div>
                        </div>
                    </t>

                    <t t-elif="state.replyHtml">
                        <div class="o_ai_brain_result_body" t-out="state.replyHtml"/>
                    </t>

                    <t t-else="">
                        <div class="o_ai_brain_empty">
                            <i class="fa fa-bar-chart fa-3x"/>
                            <p>Select a Quick Command on the left to generate a report</p>
                            <p class="o_ai_empty_sub">Or type a custom question in the message bar below</p>
                        </div>
                    </t>
                </div>

                <!-- Middle: status strip (active report + clear) -->
                <div class="o_ai_brain_status_bar">
                    <span class="o_ai_active_label">
                        <t t-if="state.activeId and state.activeId !== 'custom'">
                            <i class="fa fa-circle text-success"/> Active:
                            <strong t-esc="this.getActiveLabel()"/>
                        </t>
                        <t t-elif="state.activeId === 'custom'">
                            <i class="fa fa-circle text-primary"/> Custom query
                        </t>
                        <t t-else="">
                            <i class="fa fa-circle-o text-muted"/> No report selected
                        </t>
                    </span>
                    <button t-if="state.replyHtml or state.error"
                            class="btn btn-sm btn-outline-secondary"
                            t-on-click="onClear">
                        <i class="fa fa-times"/> Clear
                    </button>
                </div>

                <!-- Bottom: message input bar -->
                <div class="o_ai_brain_input_bar">
                    <input
                        type="text"
                        id="ai_brain_message"
                        name="ai_brain_message"
                        autocomplete="off"
                        class="o_ai_message_input"
                        placeholder="Enter message…"
                        t-model="state.customPrompt"
                        t-on-keydown="onKeydown"
                        t-att-disabled="state.loading"
                    />
                    <button class="o_ai_send_btn" t-on-click="onAsk" t-att-disabled="state.loading or !state.customPrompt">
                        <i t-attf-class="fa {{ state.loading and state.activeId === 'custom' ? 'fa-spinner fa-spin' : 'fa-arrow-right' }}"/>
                    </button>
                </div>

            </div>

        </div>
    </t>
</templates>
