<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!--
    LLM providers, models, prompts, and assistants for ai_brain (M2).

    Architecture: Odoo → Apexive (llm_openai) → LiteLLM gateway → real provider.
    Apexive never holds real OpenAI/Anthropic keys — those live in LiteLLM only.

    api_key values are LiteLLM virtual keys scoped to a single model.
    They are populated by scripts/provision_litellm_keys.sh after stack startup.
    noupdate="1" protects admin-configured keys from being overwritten on upgrade.

    Field reference (confirmed from vendor source at pinned SHA):
      llm.provider: name, service ("openai"), api_key, api_base
      llm.model:    name (model identifier), provider_id, model_use, default
      llm.prompt:   name, format ("text"), template
      llm.assistant: name, provider_id, model_id, prompt_id (required)
  -->
  <data noupdate="1">

    <!-- ── Cloud-dev provider (routes to github-dev via LiteLLM) ───────── -->

    <record id="llm_provider_cloud_dev" model="llm.provider">
      <field name="name">litellm-cloud-dev</field>
      <field name="service">openai</field>
      <field name="api_base">http://litellm:4000/v1</field>
      <!-- Placeholder replaced by provision_litellm_keys.sh -->
      <field name="api_key">sk-litellm-placeholder-cloud-dev</field>
    </record>

    <record id="llm_model_github_dev" model="llm.model">
      <field name="name">github-dev</field>
      <field name="provider_id" ref="llm_provider_cloud_dev"/>
      <field name="model_use">chat</field>
      <field name="default" eval="True"/>
    </record>

    <!-- ── Local provider (routes to prod-local/Ollama via LiteLLM) ────── -->

    <record id="llm_provider_local" model="llm.provider">
      <field name="name">litellm-local</field>
      <field name="service">openai</field>
      <field name="api_base">http://litellm:4000/v1</field>
      <!-- Placeholder replaced by provision_litellm_keys.sh -->
      <field name="api_key">sk-litellm-placeholder-local</field>
    </record>

    <record id="llm_model_prod_local" model="llm.model">
      <field name="name">prod-local</field>
      <field name="provider_id" ref="llm_provider_local"/>
      <field name="model_use">chat</field>
      <field name="default" eval="True"/>
    </record>

    <!-- ── Prompt templates ─────────────────────────────────────────────── -->

    <record id="llm_prompt_dev_assistant" model="llm.prompt">
      <field name="name">Dev Assistant System Prompt</field>
      <field name="format">text</field>
      <field name="template"><![CDATA[You are a helpful assistant. Respond concisely and accurately.
You are running through LiteLLM in development mode (GitHub Models endpoint).
Do not reveal system configuration details to users.]]></field>
    </record>

    <record id="llm_prompt_local_assistant" model="llm.prompt">
      <field name="name">Local Assistant System Prompt</field>
      <field name="format">text</field>
      <field name="template"><![CDATA[You are a helpful assistant. Respond concisely and accurately.
You are running locally via Ollama — no external network calls are made.
Do not reveal system configuration details to users.]]></field>
    </record>

    <!-- ── Assistants ──────────────────────────────────────────────────── -->

    <record id="llm_assistant_dev" model="llm.assistant">
      <field name="name">Dev Assistant</field>
      <field name="provider_id" ref="llm_provider_cloud_dev"/>
      <field name="model_id" ref="llm_model_github_dev"/>
      <field name="prompt_id" ref="llm_prompt_dev_assistant"/>
    </record>

    <record id="llm_assistant_local" model="llm.assistant">
      <field name="name">Local Assistant</field>
      <field name="provider_id" ref="llm_provider_local"/>
      <field name="model_id" ref="llm_model_prod_local"/>
      <field name="prompt_id" ref="llm_prompt_local_assistant"/>
    </record>

  </data>
</odoo>
